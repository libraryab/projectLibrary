// This is your Prisma schema file.
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ===== AUTHENTICATION =====
// Separate User model for authentication
model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("MEMBER") // MEMBER or STAFF
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  memberProfile MemberProfile?
}

// ===== LIBRARY ENTITIES =====

model Library {
  id        String   @id @default(cuid())
  name      String
  location  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  books Book[]
  staff Staff[]
}

model Publisher {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  books Book[]
}

model Book {
  id          String   @id @default(cuid())
  title       String
  publisherId String
  libraryId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  publisher    Publisher     @relation(fields: [publisherId], references: [id], onDelete: Cascade)
  library      Library       @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  authors      BookAuthor[]
  bookCopies   BookCopy[]
  loans        Loan[]
  reservations Reservation[]
}

model BookAuthor {
  id        String   @id @default(cuid())
  bookId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
}

model BookCopy {
  id        String   @id @default(cuid())
  bookId    String
  status    String   @default("AVAILABLE") // AVAILABLE, BORROWED, DAMAGED, LOST
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  book         Book          @relation(fields: [bookId], references: [id], onDelete: Cascade)
  loans        Loan[]
  reservations Reservation[]
}

model MemberProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  loans        Loan[]
  reservations Reservation[]
}

model Staff {
  id        String   @id @default(cuid())
  userId    String?
  libraryId String
  role      String // LIBRARIAN, ASSISTANT, ADMIN, etc.
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  library Library @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  loans   Loan[]
}

model Loan {
  id           String    @id @default(cuid())
  bookCopyId   String
  memberId     String
  staffId      String?
  bookId       String
  loanDate     DateTime  @default(now())
  dueDate      DateTime
  returnedDate DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  bookCopy BookCopy      @relation(fields: [bookCopyId], references: [id], onDelete: Cascade)
  member   MemberProfile @relation(fields: [memberId], references: [id], onDelete: Cascade)
  staff    Staff?        @relation(fields: [staffId], references: [id], onDelete: SetNull)
  book     Book          @relation(fields: [bookId], references: [id], onDelete: Cascade)
}

model Reservation {
  id              String   @id @default(cuid())
  bookId          String
  bookCopyId      String?
  memberId        String
  reservationDate DateTime @default(now())
  status          String   @default("ACTIVE") // ACTIVE, FULFILLED, CANCELLED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  book     Book          @relation(fields: [bookId], references: [id], onDelete: Cascade)
  bookCopy BookCopy?     @relation(fields: [bookCopyId], references: [id], onDelete: SetNull)
  member   MemberProfile @relation(fields: [memberId], references: [id], onDelete: Cascade)
}
